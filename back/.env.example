PORT=3001
# Supabase Postgres connection string. Use the CONNECTION POOLER string
# (host ...pooler.supabase.com, port 6543) for Render/serverless hosts.
# Get it from Supabase → Connect → Connection string → replace [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
