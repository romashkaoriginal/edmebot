PORT=3001

# Supabase Postgres connection string. Copy this file to .env and add the
# connection string only on your computer or in the deployment dashboard.
DATABASE_URL=

# Telegram bot token from @BotFather. Never commit the real value.
TELEGRAM_BOT_TOKEN=

# Public URLs are safe to store here; use the deployed URLs in production.
APP_URL=http://localhost:5173
# BACKEND_URL=http://localhost:3001

# Telegram ID of the first administrator.
SEED_ADMIN_TG_ID=
