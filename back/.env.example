PORT=3001
# Supabase Postgres connection string. Use the CONNECTION POOLER string
# (host ...pooler.supabase.com, port 6543) for Render/serverless hosts.
# Get it from Supabase → Connect → Connection string → replace [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Telegram bot (webhook mode). Get the token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AA...
# Frontend URL (Vercel) opened as the Telegram Mini App when /start is sent.
APP_URL=https://edmebot.vercel.app
# Only needed outside Render (Render sets RENDER_EXTERNAL_URL automatically).
# BACKEND_URL=https://your-backend.example.com

# Telegram id of the first admin. Seeded into the users table on first boot
# (only if the users table is empty) so someone can access the admin panel.
SEED_ADMIN_TG_ID=123456789
